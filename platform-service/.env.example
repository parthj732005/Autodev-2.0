# Copy to a .env file at the repo root (used by docker-compose.yml) and fill
# in real values for anything beyond local development. Never commit a real
# .env file or real secrets.

DB_NAME=autodev_platform
DB_USERNAME=autodev
DB_PASSWORD=autodev

# Generate a real random 32+ byte secret for anything beyond local dev, e.g.:
#   openssl rand -base64 48
JWT_SECRET=dev-only-secret-change-me-please-this-is-not-for-production-use-32bytes-min
JWT_EXPIRATION_MINUTES=60

# Base64-encoded 32-byte (256-bit) AES key, used to encrypt provider API keys
# at rest (AES-256-GCM). Generate a real one for anything beyond local dev:
#   openssl rand -base64 32
# Missing/malformed/wrong-size values cause credential encrypt/decrypt calls
# to fail safely (never falls back to plaintext) — see CredentialEncryptor.
AUTODEV_CREDENTIAL_ENCRYPTION_KEY=s0RjHUzD329Zk7wmpWVKKpFLNAiDQvBF83chS5N70Mw=

# Base URL the FastAPI backend will use to reach this service.
PLATFORM_SERVICE_URL=http://localhost:8081
